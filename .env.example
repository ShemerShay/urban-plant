# Copy to .env.local and fill in (or run: npm run setup:env)

# Admin area (middleware-protected routes)
ADMIN_PASSWORD=

# Resend (order confirmation email)
RESEND_API_KEY=
# Verified sender in Resend, e.g. Urban Plant <orders@yourdomain.com>
RESEND_FROM=

# Customer WhatsApp (digits only, country code, no +) e.g. 972501234567
NEXT_PUBLIC_WHATSAPP_PHONE=

# Optional analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
